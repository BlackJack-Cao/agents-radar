# Required: GitHub API token. Fine-grained read-only token is enough for local file output.
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Required: choose one LLM provider.
# OpenAI-compatible proxy/provider.
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=http://192.168.31.36:8080/v1
OPENAI_MODEL=gpt-5.4-mini

# Optional: false generates Chinese only; true restores Chinese and English reports.
GENERATE_ENGLISH=false

# Alternative DeepSeek provider.
# LLM_PROVIDER=deepseek
# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
# DEEPSEEK_MODEL=deepseek-chat

# Optional: Product Hunt digest. If unset, Product Hunt is skipped.
# PRODUCTHUNT_TOKEN=xxxxxxxxxxxxxxxxxxxx

# Required for Feishu push. Multiple webhooks can be comma-separated.
FEISHU_WEBHOOK_URLS=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Link base shown in Feishu card. For local-only use, keep this localhost URL.
# For phone/outside access, change it to GitHub Pages or an intranet tunnel URL.
PAGES_URL=http://localhost:8080

# Optional: set DIGEST_REPO only if you want the script to create GitHub Issues.
# For local deployment, leave it empty.
# DIGEST_REPO=your-github-user/agents-radar
